{
  "name": "guava-engine",
  "private": true,
  "description": "Guava Engine — Zig game engine with Electron editor",
  "scripts": {
    "codegen": "cd packages/editor && npm run codegen",
    "compile-commands": "cd packages/engine && zig build compile-commands",
    "editor:dev": "cd packages/editor && npm run dev",
    "editor:build": "cd packages/editor && npm run build",
    "editor:install": "cd packages/editor && npm install",
    "engine:build": "cd packages/engine && zig build install",
    "engine:run-editor": "cd packages/engine && zig build run-editor",
    "engine:run-editor-fast": "cd packages/engine && zig build run-editor -Doptimize=ReleaseFast"
  }
}
