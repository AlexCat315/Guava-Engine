{
  "name": "guava-engine",
  "private": true,
  "description": "Guava Engine — Swift game engine with GuavaUI and editor",
  "scripts": {
    "engine:build": "cd Engine && swift build",
    "engine:run": "cd Engine && swift run",
    "guavaui:build": "cd GuavaUI && swift build",
    "editor:build": "cd Editor && swift build",
    "editor:run": "cd Editor && swift run EditorApp",
    "wgpu:fetch": "cd Engine && bash scripts/fetch-wgpu.sh",
    "legacy:editor:dev": "cd legacy/react-editor && npm run dev",
    "legacy:engine:build": "cd legacy/zig-engine && zig build install"
  }
}
