{
  "name": "guava-editor",
  "version": "0.1.0",
  "description": "Guava Engine Editor — Electron-based editor frontend",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron dist/main/index.js",
    "build:native": "cd native && node-gyp rebuild --target=$(node -e \"console.log(require('electron/package.json').version)\") --arch=arm64 --dist-url=https://electronjs.org/headers",
    "rebuild": "electron-rebuild -f -m native",
    "postinstall": "npm run rebuild || true",
    "codegen": "cd .. && zig run src/engine/editor_rpc/gen_types.zig 2> editor-electron/src/shared/rpc-types.generated.ts",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^24.11.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "react-devtools": "^7.0.1"
  }
}
