{
  "name": "guava-editor",
  "version": "0.1.0",
  "description": "Guava Engine Editor — Electron-based editor frontend",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron dist/main/index.js",
    "codegen": "cd .. && zig run src/engine/editor_rpc/gen_types.zig 2> editor-electron/src/shared/rpc-types.generated.ts",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^33.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  }
}
