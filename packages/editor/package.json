{
  "name": "guava-editor",
  "version": "0.1.0",
  "description": "Guava Engine Editor — Citron-based editor frontend",
  "scripts": {
    "dev": "npm run codegen && citron dev",
    "dev:frontend": "vite",
    "build:frontend": "vite build",
    "build": "npm run codegen && citron build",
    "codegen": "cd ../engine && zig run src/engine/editor_rpc/gen_types.zig 2> ../editor/src/shared/rpc-types.generated.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xyflow/react": "^12.10.2",
    "flexlayout-react": "^0.8.19",
    "immer": "^11.1.4",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.11.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3"
  }
}
