{
  "name": "guava-editor",
  "version": "0.1.0",
  "description": "Guava Engine Editor — Electron-based editor frontend",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron dist/main/index.js",
    "build:native": "cd native && npx cmake-js compile --runtime=electron --runtime-version=$(node -e \"console.log(require('electron/package.json').version)\")",
    "rebuild": "cd native && npx cmake-js rebuild --runtime=electron --runtime-version=$(node -e \"console.log(require('electron/package.json').version)\")",
    "postinstall": "npm run build:native || true",
    "codegen": "cd ../engine && zig run src/engine/editor_rpc/gen_types.zig 2> ../editor/src/shared/rpc-types.generated.ts",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "flexlayout-react": "^0.8.19",
    "immer": "^11.1.4",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^24.11.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^6.0.1",
    "cmake-js": "^8.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "node-addon-api": "^8.7.0",
    "react": "^19.2.4",
    "react-devtools": "^7.0.1",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1"
  }
}
