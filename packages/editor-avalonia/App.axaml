<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Guava.Editor.App"
             xmlns:local="using:Guava.Editor"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Guava.Editor/Themes/CatppuccinMocha.axaml" />
    </Application.Styles>
</Application>