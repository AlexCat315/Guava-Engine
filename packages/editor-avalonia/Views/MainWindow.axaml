<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Guava.Editor.ViewModels"
        xmlns:panels="using:Guava.Editor.Views.Panels"
        xmlns:idc="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
        xmlns:loc="using:Guava.Editor.Markup"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="Guava.Editor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{loc:T app.title}"
        Width="1440" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BaseBrush}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.KeyBindings>
        <!-- Ctrl+, opens Settings (matches old React editor's keybinding) -->
        <KeyBinding Gesture="Ctrl+OemComma" Command="{Binding OpenSettingsCommand}"/>
    </Window.KeyBindings>

    <!-- Panel layer: Dock + toolbar + status bar in a Grid; Settings modal overlays everything -->
    <Panel>
        <Grid RowDefinitions="44,*,24">

        <!-- ============== Toolbar ============== -->
        <Border Grid.Row="0"
                Background="{DynamicResource MantleBrush}"
                BorderBrush="{DynamicResource Surface0Brush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <!-- Left: brand + connection -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Left" Margin="16,0" Spacing="10">
                    <TextBlock Text="{loc:T toolbar.brand}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Border Classes="vsep" Height="18"/>
                    <Ellipse Classes="status-dot"
                             Fill="{DynamicResource GreenBrush}"/>
                    <TextBlock Text="{Binding Connection.StatusText}"
                               Foreground="{DynamicResource Overlay0Brush}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Center: transport -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Spacing="2">
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.play}">
                        <svg:Svg Path="{StaticResource PlayIcon}" Width="15" Height="15"
                                 IsHitTestVisible="False"
                                 Css="{DynamicResource SvgCssGreen}"/>
                    </Button>
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.pause}">
                        <svg:Svg Path="{StaticResource PauseIcon}" Width="15" Height="15"
                                 IsHitTestVisible="False"
                                 Css="{DynamicResource SvgCssText}"/>
                    </Button>
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.stop}">
                        <svg:Svg Path="{StaticResource StopIcon}" Width="15" Height="15"
                                 IsHitTestVisible="False"
                                 Css="{DynamicResource SvgCssRed}"/>
                    </Button>
                </StackPanel>

                <!-- Right: file actions -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Right" Margin="16,0" Spacing="2">
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.save}">
                        <svg:Svg Path="{StaticResource SaveIcon}" Width="15" Height="15"
                                 IsHitTestVisible="False"
                                 Css="{DynamicResource SvgCssText}"/>
                    </Button>
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.undo}">
                        <svg:Svg Path="{StaticResource UndoIcon}" Width="15" Height="15"
                                 IsHitTestVisible="False"
                                 Css="{DynamicResource SvgCssText}"/>
                    </Button>
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.redo}">
                        <svg:Svg Path="{StaticResource RedoIcon}" Width="15" Height="15"
                                 IsHitTestVisible="False"
                                 Css="{DynamicResource SvgCssText}"/>
                    </Button>
                    <Border Classes="vsep" Height="18" Margin="6,0"/>
                    <Button x:Name="SettingsButton" Classes="toolbar"
                            ToolTip.Tip="{loc:T toolbar.settings}"
                            Click="OnSettingsClick">
                        <svg:Svg Path="{StaticResource CogIcon}" Width="15" Height="15"
                                 IsHitTestVisible="False"
                                 Css="{DynamicResource SvgCssOverlay0}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============== Dock ============== -->
        <idc:DockControl Grid.Row="1" Layout="{Binding Layout}"/>

        <!-- ============== Status bar ============== -->
        <Border Grid.Row="2"
                Background="{DynamicResource CrustBrush}"
                BorderBrush="{DynamicResource Surface0Brush}"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="16,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="{DynamicResource GreenBrush}"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource Overlay0Brush}"
                               FontSize="10.5" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Connection.StatusText}"
                           Foreground="{DynamicResource Overlay0Brush}"
                           FontSize="10.5" VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
        </Grid>

        <!-- ============== Settings draggable-modal overlay ============== -->
        <!-- Mirrors old React editor's DraggableSettingsModal: semi-transparent
             backdrop (click to dismiss) + centered card with draggable header. -->
        <Border x:Name="SettingsBackdrop"
                IsVisible="{Binding IsSettingsOpen}"
                Background="#99000000"
                PointerPressed="OnSettingsBackdropPressed">
            <Border x:Name="SettingsCard"
                    Width="860" Height="560"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource BaseBrush}"
                    BorderBrush="{DynamicResource Surface0Brush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    BoxShadow="0 16 48 0 #80000000"
                    PointerPressed="OnSettingsCardPressed"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TranslateTransform X="0" Y="0"/>
                </Border.RenderTransform>
                <Grid RowDefinitions="36,*">
                    <!-- Draggable header -->
                    <Border x:Name="SettingsHeader" Grid.Row="0"
                            Background="{DynamicResource MantleBrush}"
                            BorderBrush="{DynamicResource Surface0Brush}"
                            BorderThickness="0,0,0,1"
                            PointerPressed="OnSettingsHeaderPressed"
                            PointerMoved="OnSettingsHeaderMoved"
                            PointerReleased="OnSettingsHeaderReleased"
                            Cursor="SizeAll">
                        <Grid>
                            <TextBlock Text="{loc:T settings.title}"
                                       Margin="16,0" VerticalAlignment="Center"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <Button x:Name="SettingsCloseButton"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,6,0" Width="28" Height="26"
                                    Background="Transparent" BorderThickness="0"
                                    Command="{Binding CloseSettingsCommand}"
                                    ToolTip.Tip="Close (Esc)">
                                <svg:Svg Path="{StaticResource CloseIcon}"
                                         Width="12" Height="12"
                                         Css="{DynamicResource SvgCssSubtext0}"
                                         IsHitTestVisible="False"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Settings body -->
                    <panels:SettingsPanelView Grid.Row="1" DataContext="{Binding Settings}"/>
                </Grid>
            </Border>
        </Border>

    </Panel>
</Window>
