<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Guava.Editor.ViewModels"
        xmlns:idc="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
        xmlns:loc="using:Guava.Editor.Markup"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="Guava.Editor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{loc:T app.title}"
        Width="1440" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BaseBrush}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="44,*,24">

        <!-- ============== Toolbar ============== -->
        <Border Grid.Row="0"
                Background="{DynamicResource MantleBrush}"
                BorderBrush="{DynamicResource Surface0Brush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <!-- Left: brand + connection -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Left" Margin="16,0" Spacing="10">
                    <TextBlock Text="{loc:T toolbar.brand}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Border Classes="vsep" Height="18"/>
                    <Ellipse Classes="status-dot"
                             Fill="{DynamicResource GreenBrush}"/>
                    <TextBlock Text="{Binding Connection.StatusText}"
                               Foreground="{DynamicResource Overlay0Brush}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Center: transport -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Spacing="2">
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.play}">
                        <svg:Svg Path="{StaticResource PlayIcon}" Width="15" Height="15"
                                 Css="{DynamicResource SvgCssGreen}"/>
                    </Button>
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.pause}">
                        <svg:Svg Path="{StaticResource PauseIcon}" Width="15" Height="15"
                                 Css="{DynamicResource SvgCssText}"/>
                    </Button>
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.stop}">
                        <svg:Svg Path="{StaticResource StopIcon}" Width="15" Height="15"
                                 Css="{DynamicResource SvgCssRed}"/>
                    </Button>
                </StackPanel>

                <!-- Right: file actions -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Right" Margin="16,0" Spacing="2">
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.save}">
                        <svg:Svg Path="{StaticResource SaveIcon}" Width="15" Height="15"
                                 Css="{DynamicResource SvgCssText}"/>
                    </Button>
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.undo}">
                        <svg:Svg Path="{StaticResource UndoIcon}" Width="15" Height="15"
                                 Css="{DynamicResource SvgCssText}"/>
                    </Button>
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.redo}">
                        <svg:Svg Path="{StaticResource RedoIcon}" Width="15" Height="15"
                                 Css="{DynamicResource SvgCssText}"/>
                    </Button>
                    <Border Classes="vsep" Height="18" Margin="6,0"/>
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.settings}"
                            Command="{Binding OpenSettingsCommand}">
                        <svg:Svg Path="{StaticResource CogIcon}" Width="15" Height="15"
                                 Css="{DynamicResource SvgCssOverlay0}"/>
                    </Button>
                    <Button Classes="toolbar" ToolTip.Tip="{loc:T toolbar.toggle_theme}"
                            Command="{Binding ToggleLanguageCommand}">
                        <TextBlock Text="{Binding CurrentLanguageLabel}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Subtext0Brush}"
                                   VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============== Dock ============== -->
        <idc:DockControl Grid.Row="1" Layout="{Binding Layout}"/>

        <!-- ============== Status bar ============== -->
        <Border Grid.Row="2"
                Background="{DynamicResource CrustBrush}"
                BorderBrush="{DynamicResource Surface0Brush}"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="16,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="{DynamicResource GreenBrush}"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource Overlay0Brush}"
                               FontSize="10.5" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Connection.StatusText}"
                           Foreground="{DynamicResource Overlay0Brush}"
                           FontSize="10.5" VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
