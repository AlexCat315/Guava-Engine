<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Guava.Editor.ViewModels"
        xmlns:idc="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="Guava.Editor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Guava Editor"
        Width="1440" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Base}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="40,*,28">
        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource MantleBrush}">
            <DockPanel Margin="12,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🥑 Guava Editor" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="  |  " Foreground="{DynamicResource Overlay0}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ConnectionStatus}" Foreground="{DynamicResource GreenBrush}" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Content="💾" FontSize="14" Padding="6,2" Margin="2,0" ToolTip.Tip="Save"/>
                    <Button Content="↩" FontSize="14" Padding="6,2" Margin="2,0" ToolTip.Tip="Undo"/>
                    <Button Content="↪" FontSize="14" Padding="6,2" Margin="2,0" ToolTip.Tip="Redo"/>
                    <TextBlock Text="  |  " Foreground="{DynamicResource Overlay0}" VerticalAlignment="Center"/>
                    <Button Content="▶" FontSize="14" Padding="8,2" Margin="2,0" ToolTip.Tip="Play"
                            Foreground="{DynamicResource GreenBrush}"/>
                    <Button Content="⏸" FontSize="14" Padding="8,2" Margin="2,0" ToolTip.Tip="Pause"/>
                    <Button Content="⏹" FontSize="14" Padding="8,2" Margin="2,0" ToolTip.Tip="Stop"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Dock Control -->
        <idc:DockControl Grid.Row="1" Layout="{Binding Layout}"/>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{DynamicResource MantleBrush}">
            <DockPanel Margin="12,0">
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Foreground="{DynamicResource Subtext1Brush}" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding ConnectionStatus}" Foreground="{DynamicResource GreenBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
