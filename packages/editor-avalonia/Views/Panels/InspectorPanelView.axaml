<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Guava.Editor.ViewModels.Panels"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             x:Class="Guava.Editor.Views.Panels.InspectorPanelView"
             x:DataType="vm:InspectorPanelViewModel">
    <ScrollViewer>
        <StackPanel Margin="10,8">
            <!-- Entity name -->
            <TextBox Text="Cube" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <!-- Transform section -->
            <Border Background="{DynamicResource MantleBrush}" CornerRadius="8" Padding="10,8" Margin="0,0,0,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                        <svg:Svg Path="{StaticResource MoveIcon}" Width="13" Height="13" Css="{DynamicResource SvgCssBlue}" VerticalAlignment="Center"/>
                        <TextBlock Text="Transform" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="56,24,*,8,24,*,8,24,*" RowDefinitions="Auto,8,Auto,8,Auto" Margin="0,0,0,2">
                        <!-- Position -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Position" FontSize="10.5" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Subtext0Brush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="X" FontSize="10.5" VerticalAlignment="Center"
                                   Foreground="{DynamicResource RedBrush}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="2" Text="0.00" FontSize="10.5" Padding="6,3"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" />
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Y" FontSize="10.5" VerticalAlignment="Center"
                                   Foreground="{DynamicResource GreenBrush}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="5" Text="0.00" FontSize="10.5" Padding="6,3"/>
                        <TextBlock Grid.Row="0" Grid.Column="6" />
                        <TextBlock Grid.Row="0" Grid.Column="7" Text="Z" FontSize="10.5" VerticalAlignment="Center"
                                   Foreground="{DynamicResource BlueBrush}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="8" Text="0.00" FontSize="10.5" Padding="6,3"/>
                        <!-- Rotation -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Rotation" FontSize="10.5" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Subtext0Brush}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="X" FontSize="10.5" VerticalAlignment="Center"
                                   Foreground="{DynamicResource RedBrush}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="2" Text="0.00" FontSize="10.5" Padding="6,3"/>
                        <TextBlock Grid.Row="2" Grid.Column="4" Text="Y" FontSize="10.5" VerticalAlignment="Center"
                                   Foreground="{DynamicResource GreenBrush}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="5" Text="0.00" FontSize="10.5" Padding="6,3"/>
                        <TextBlock Grid.Row="2" Grid.Column="7" Text="Z" FontSize="10.5" VerticalAlignment="Center"
                                   Foreground="{DynamicResource BlueBrush}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="8" Text="0.00" FontSize="10.5" Padding="6,3"/>
                        <!-- Scale -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Scale" FontSize="10.5" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Subtext0Brush}"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="X" FontSize="10.5" VerticalAlignment="Center"
                                   Foreground="{DynamicResource RedBrush}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox Grid.Row="4" Grid.Column="2" Text="1.00" FontSize="10.5" Padding="6,3"/>
                        <TextBlock Grid.Row="4" Grid.Column="4" Text="Y" FontSize="10.5" VerticalAlignment="Center"
                                   Foreground="{DynamicResource GreenBrush}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox Grid.Row="4" Grid.Column="5" Text="1.00" FontSize="10.5" Padding="6,3"/>
                        <TextBlock Grid.Row="4" Grid.Column="7" Text="Z" FontSize="10.5" VerticalAlignment="Center"
                                   Foreground="{DynamicResource BlueBrush}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBox Grid.Row="4" Grid.Column="8" Text="1.00" FontSize="10.5" Padding="6,3"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Components section -->
            <Border Background="{DynamicResource MantleBrush}" CornerRadius="8" Padding="10,8" Margin="0,0,0,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                        <svg:Svg Path="{StaticResource CubeIcon}" Width="13" Height="13" Css="{DynamicResource SvgCssMauve}" VerticalAlignment="Center"/>
                        <TextBlock Text="Components" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="{DynamicResource BaseBrush}" CornerRadius="6" Padding="10,7" Margin="0,2">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <svg:Svg Path="{StaticResource CubeIcon}" Width="13" Height="13" Css="{DynamicResource SvgCssSapphire}" VerticalAlignment="Center"/>
                            <TextBlock Text="MeshRenderer" FontSize="11.5" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource BaseBrush}" CornerRadius="6" Padding="10,7" Margin="0,2">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <svg:Svg Path="{StaticResource SphereIcon}" Width="13" Height="13" Css="{DynamicResource SvgCssTeal}" VerticalAlignment="Center"/>
                            <TextBlock Text="RigidBody" FontSize="11.5" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource BaseBrush}" CornerRadius="6" Padding="10,7" Margin="0,2">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <svg:Svg Path="{StaticResource CubeIcon}" Width="13" Height="13" Css="{DynamicResource SvgCssPeach}" VerticalAlignment="Center"/>
                            <TextBlock Text="BoxCollider" FontSize="11.5" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Button HorizontalAlignment="Stretch" Padding="0,7" CornerRadius="8"
                    Background="{DynamicResource Surface0Brush}" BorderThickness="1"
                    BorderBrush="{DynamicResource Surface1Brush}">
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <svg:Svg Path="{StaticResource PlusIcon}" Width="13" Height="13" Css="{DynamicResource SvgCssBlue}" VerticalAlignment="Center"/>
                    <TextBlock Text="Add Component" FontSize="11.5" Foreground="{DynamicResource Subtext0Brush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
