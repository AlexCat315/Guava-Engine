<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Guava.Editor.ViewModels.Panels"
             xmlns:native="using:Guava.Editor.Native"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             x:Class="Guava.Editor.Views.Panels.ViewportPanelView"
             x:DataType="vm:ViewportPanelViewModel">
    <Grid SizeChanged="OnRootSizeChanged">

        <!-- Engine viewport via IOSurface (zero-copy GPU, Avalonia visual tree) -->
        <native:IOSurfaceHost x:Name="ViewportHost"
                              SurfaceId="{Binding SurfaceId}" />

        <!-- Status when not yet connected -->
        <TextBlock Text="{Binding StatusText}"
                   IsVisible="{Binding !SurfaceId}"
                   Foreground="{DynamicResource Overlay1Brush}"
                   FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- FPS counter -->
        <Border Background="{DynamicResource ViewportFpsBgBrush}"
                CornerRadius="4" Padding="6,3"
                HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="6">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <svg:Svg Path="{StaticResource CrosshairIcon}" Width="12" Height="12"
                         Css="{DynamicResource SvgCssGreen}"/>
                <TextBlock Text="{Binding FpsText}"
                           Foreground="{DynamicResource GreenBrush}"
                           FontSize="11" FontFamily="Menlo,Consolas,monospace"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding DrawCallsText}"
                           Foreground="{DynamicResource Subtext0Brush}"
                           FontSize="11" FontFamily="Menlo,Consolas,monospace"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ViewCube placeholder -->
        <Border Background="{DynamicResource ViewportCubeBgBrush}"
                CornerRadius="4" Width="50" Height="50"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8">
            <svg:Svg Path="{StaticResource CubeIcon}" Width="24" Height="24"
                     Css="{DynamicResource SvgCssText}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
