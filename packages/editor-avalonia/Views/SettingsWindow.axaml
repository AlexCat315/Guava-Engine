<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Guava.Editor.ViewModels"
        xmlns:loc="using:Guava.Editor.Markup"
        mc:Ignorable="d"
        x:Class="Guava.Editor.Views.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Title="{loc:T settings.title}"
        Width="780" Height="540"
        MinWidth="620" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        TransparencyLevelHint="Mica"
        Background="{DynamicResource BaseBrush}"
        ExtendClientAreaToDecorationsHint="False">
    <Design.DataContext>
        <vm:SettingsWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="180,*" Background="{DynamicResource BaseBrush}">

        <!-- Left nav -->
        <Border Grid.Column="0"
                Background="{DynamicResource MantleBrush}"
                BorderBrush="{DynamicResource Surface0Brush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="0,12">
                <TextBlock Text="{loc:T settings.title}"
                           Margin="16,4,16,12"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"/>
                <ListBox ItemsSource="{Binding Sections}"
                         SelectedItem="{Binding SelectedSection}"
                         Background="Transparent"
                         BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Right content -->
        <ScrollViewer Grid.Column="1" Padding="28,20" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="22" MaxWidth="520" HorizontalAlignment="Left">

                <!-- Language -->
                <StackPanel IsVisible="{Binding SelectedSection, Converter={x:Static loc:EqualsConverter.Instance}, ConverterParameter=Language}"
                            Classes="panel-section" Spacing="12">
                    <TextBlock Classes="panel-header" Text="{loc:T settings.navLanguage}"/>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <RadioButton GroupName="lang" Content="English"
                                     IsChecked="{Binding !IsChinese}"/>
                        <RadioButton GroupName="lang" Content="中文"
                                     IsChecked="{Binding IsChinese}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Appearance -->
                <StackPanel IsVisible="{Binding SelectedSection, Converter={x:Static loc:EqualsConverter.Instance}, ConverterParameter=Appearance}"
                            Classes="panel-section" Spacing="12">
                    <TextBlock Classes="panel-header" Text="{loc:T settings.navAppearance}"/>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <RadioButton GroupName="theme" Content="Dark"
                                     IsChecked="{Binding IsDarkTheme}"/>
                        <RadioButton GroupName="theme" Content="Light"
                                     IsChecked="{Binding !IsDarkTheme}"/>
                    </StackPanel>
                    <CheckBox Content="{loc:T settings.showFps}" IsChecked="{Binding Prefs.ShowFps}"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{loc:T settings.maxLogs}" VerticalAlignment="Center" Width="140"/>
                        <NumericUpDown Value="{Binding Prefs.MaxConsoleLogs}" Minimum="100" Maximum="10000" Increment="100" Width="140"/>
                    </StackPanel>
                </StackPanel>

                <!-- Engine -->
                <StackPanel IsVisible="{Binding SelectedSection, Converter={x:Static loc:EqualsConverter.Instance}, ConverterParameter=Engine}"
                            Classes="panel-section" Spacing="12">
                    <TextBlock Classes="panel-header" Text="{loc:T settings.navRemote}"/>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <RadioButton GroupName="mode" Content="Local"
                                     IsChecked="{Binding Prefs.EngineMode, Mode=TwoWay, Converter={x:Static loc:EqualsConverter.Instance}, ConverterParameter=local}"/>
                        <RadioButton GroupName="mode" Content="Remote"
                                     IsChecked="{Binding Prefs.EngineMode, Mode=TwoWay, Converter={x:Static loc:EqualsConverter.Instance}, ConverterParameter=remote}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Port" Width="140" VerticalAlignment="Center"/>
                        <NumericUpDown Value="{Binding Prefs.EnginePort}" Minimum="1024" Maximum="65535" Width="140"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Remote URL" Width="140" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Prefs.RemoteEngineUrl}" Width="260"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="primary" Content="{loc:T settings.test}"
                                Command="{Binding TestConnectionCommand}"
                                IsEnabled="{Binding !IsTesting}"/>
                        <Button Content="{loc:T settings.reconnect}"
                                Command="{Binding ReconnectCommand}"/>
                        <TextBlock Text="{Binding TestStatus}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Overlay0Brush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- About -->
                <StackPanel IsVisible="{Binding SelectedSection, Converter={x:Static loc:EqualsConverter.Instance}, ConverterParameter=About}"
                            Classes="panel-section" Spacing="8">
                    <TextBlock Classes="panel-header" Text="{loc:T settings.navAbout}"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Editor" Width="140" Foreground="{DynamicResource Subtext0Brush}"/>
                        <TextBlock Text="Guava Editor — Avalonia"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Engine" Width="140" Foreground="{DynamicResource Subtext0Brush}"/>
                        <TextBlock Text="{Binding EngineVersion}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Connection" Width="140" Foreground="{DynamicResource Subtext0Brush}"/>
                        <TextBlock Text="{Binding Connection.StatusText}"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
