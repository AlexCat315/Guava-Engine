<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Panel composition helpers.
        Reusable "section header" and "field row" visual primitives so panel views
        stop duplicating the same Border/StackPanel scaffolding.
    -->

    <!-- Panel section container: rounded Mantle card with padding -->
    <Style Selector="Border.panel-section">
        <Setter Property="Background" Value="{DynamicResource MantleBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- Inner card (on top of a section) -->
    <Style Selector="Border.panel-card">
        <Setter Property="Background" Value="{DynamicResource BaseBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Margin" Value="0,2" />
    </Style>

    <!-- Section header label -->
    <Style Selector="TextBlock.panel-header">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Label in a field row -->
    <Style Selector="TextBlock.field-label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource Subtext0Brush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Axis labels (XYZ) -->
    <Style Selector="TextBlock.axis-x">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource RedBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.axis-y">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource GreenBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.axis-z">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource BlueBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Vertical separator 1px -->
    <Style Selector="Border.vsep">
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <!-- Status dot 7px -->
    <Style Selector="Ellipse.status-dot">
        <Setter Property="Width" Value="7" />
        <Setter Property="Height" Value="7" />
    </Style>
</Styles>
