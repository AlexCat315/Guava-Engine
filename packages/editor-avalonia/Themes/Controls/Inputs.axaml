<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- TextBox -->
    <Style Selector="TextBox">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource BlueBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource BlueBrush}" />
        <Setter Property="SelectionForegroundBrush" Value="{DynamicResource CrustBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="MinHeight" Value="28" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource BlueBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource Surface2Brush}" />
    </Style>
    <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
        <Setter Property="Foreground" Value="{DynamicResource Overlay0Brush}" />
    </Style>

    <!-- NumericUpDown -->
    <Style Selector="NumericUpDown">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- CheckBox -->
    <Style Selector="CheckBox">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <!-- RadioButton -->
    <Style Selector="RadioButton">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <!-- Slider -->
    <Style Selector="Slider">
        <Setter Property="Foreground" Value="{DynamicResource BlueBrush}" />
    </Style>
    <Style Selector="Slider /template/ Track#PART_Track /template/ Border#TrackBackground">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    </Style>

    <!-- ToggleSwitch (if used) -->
    <Style Selector="ToggleSwitch">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
</Styles>
