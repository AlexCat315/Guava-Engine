<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <!-- Catppuccin Latte palette -->
        <Color x:Key="Rosewater">#dc8a78</Color>
        <Color x:Key="Flamingo">#dd7878</Color>
        <Color x:Key="Pink">#ea76cb</Color>
        <Color x:Key="Mauve">#8839ef</Color>
        <Color x:Key="Red">#d20f39</Color>
        <Color x:Key="Maroon">#e64553</Color>
        <Color x:Key="Peach">#fe640b</Color>
        <Color x:Key="Yellow">#df8e1d</Color>
        <Color x:Key="Green">#40a02b</Color>
        <Color x:Key="Teal">#179299</Color>
        <Color x:Key="Sky">#04a5e5</Color>
        <Color x:Key="Sapphire">#209fb5</Color>
        <Color x:Key="Blue">#1e66f5</Color>
        <Color x:Key="Lavender">#7287fd</Color>

        <Color x:Key="Text">#4c4f69</Color>
        <Color x:Key="Subtext1">#5c5f77</Color>
        <Color x:Key="Subtext0">#6c6f85</Color>
        <Color x:Key="Overlay2">#7c7f93</Color>
        <Color x:Key="Overlay1">#8c8fa1</Color>
        <Color x:Key="Overlay0">#9ca0b0</Color>
        <Color x:Key="Surface2">#acb0be</Color>
        <Color x:Key="Surface1">#bcc0cc</Color>
        <Color x:Key="Surface0">#ccd0da</Color>
        <Color x:Key="Base">#eff1f5</Color>
        <Color x:Key="Mantle">#e6e9ef</Color>
        <Color x:Key="Crust">#dce0e8</Color>

        <!-- Brushes for easy binding -->
        <!-- Viewport overlay colors (with alpha) -->
        <Color x:Key="ViewportOverlayBg">#CCeff1f5</Color>
        <Color x:Key="ViewportFpsBg">#CCdce0e8</Color>
        <Color x:Key="ViewportCubeBg">#BBe6e9ef</Color>

        <SolidColorBrush x:Key="ViewportOverlayBgBrush" Color="{DynamicResource ViewportOverlayBg}" />
        <SolidColorBrush x:Key="ViewportFpsBgBrush" Color="{DynamicResource ViewportFpsBg}" />
        <SolidColorBrush x:Key="ViewportCubeBgBrush" Color="{DynamicResource ViewportCubeBg}" />

        <SolidColorBrush x:Key="BaseBrush" Color="{DynamicResource Base}" />
        <SolidColorBrush x:Key="MantleBrush" Color="{DynamicResource Mantle}" />
        <SolidColorBrush x:Key="CrustBrush" Color="{DynamicResource Crust}" />
        <SolidColorBrush x:Key="Surface0Brush" Color="{DynamicResource Surface0}" />
        <SolidColorBrush x:Key="Surface1Brush" Color="{DynamicResource Surface1}" />
        <SolidColorBrush x:Key="Surface2Brush" Color="{DynamicResource Surface2}" />
        <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource Text}" />
        <SolidColorBrush x:Key="Subtext1Brush" Color="{DynamicResource Subtext1}" />
        <SolidColorBrush x:Key="Subtext0Brush" Color="{DynamicResource Subtext0}" />
        <SolidColorBrush x:Key="Overlay0Brush" Color="{DynamicResource Overlay0}" />
        <SolidColorBrush x:Key="Overlay2Brush" Color="{DynamicResource Overlay2}" />
        <SolidColorBrush x:Key="BlueBrush" Color="{DynamicResource Blue}" />
        <SolidColorBrush x:Key="GreenBrush" Color="{DynamicResource Green}" />
        <SolidColorBrush x:Key="RedBrush" Color="{DynamicResource Red}" />
        <SolidColorBrush x:Key="YellowBrush" Color="{DynamicResource Yellow}" />
        <SolidColorBrush x:Key="PeachBrush" Color="{DynamicResource Peach}" />
        <SolidColorBrush x:Key="MauveBrush" Color="{DynamicResource Mauve}" />
        <SolidColorBrush x:Key="SapphireBrush" Color="{DynamicResource Sapphire}" />
        <SolidColorBrush x:Key="TealBrush" Color="{DynamicResource Teal}" />
        <SolidColorBrush x:Key="SkyBrush" Color="{DynamicResource Sky}" />
        <SolidColorBrush x:Key="LavenderBrush" Color="{DynamicResource Lavender}" />

        <!-- SVG CSS color overrides (for Svg.Controls.Skia.Avalonia) -->
        <x:String x:Key="SvgCssText">path[fill] { fill: #4c4f69; } path[stroke] { stroke: #4c4f69; }</x:String>
        <x:String x:Key="SvgCssOverlay0">path[fill] { fill: #9ca0b0; } path[stroke] { stroke: #9ca0b0; }</x:String>
        <x:String x:Key="SvgCssBlue">path[fill] { fill: #1e66f5; } path[stroke] { stroke: #1e66f5; }</x:String>
        <x:String x:Key="SvgCssGreen">path[fill] { fill: #40a02b; } path[stroke] { stroke: #40a02b; }</x:String>
        <x:String x:Key="SvgCssRed">path[fill] { fill: #d20f39; } path[stroke] { stroke: #d20f39; }</x:String>
        <x:String x:Key="SvgCssYellow">path[fill] { fill: #df8e1d; } path[stroke] { stroke: #df8e1d; }</x:String>
        <x:String x:Key="SvgCssPeach">path[fill] { fill: #fe640b; } path[stroke] { stroke: #fe640b; }</x:String>
        <x:String x:Key="SvgCssMauve">path[fill] { fill: #8839ef; } path[stroke] { stroke: #8839ef; }</x:String>
        <x:String x:Key="SvgCssSapphire">path[fill] { fill: #209fb5; } path[stroke] { stroke: #209fb5; }</x:String>
        <x:String x:Key="SvgCssTeal">path[fill] { fill: #179299; } path[stroke] { stroke: #179299; }</x:String>
        <x:String x:Key="SvgCssOverlay2">path[fill] { fill: #7c7f93; } path[stroke] { stroke: #7c7f93; }</x:String>
</ResourceDictionary>
