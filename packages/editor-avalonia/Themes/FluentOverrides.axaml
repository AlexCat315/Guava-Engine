<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia">
    <!--
        Fluent theme semantic overrides.
        Fluent theme renders many controls (ScrollBar, MenuFlyout, ComboBox, TabControl, ToolTip,
        TreeView selection, window chrome) with its own internal brush keys. When we only set our
        Catppuccin palette on container Backgrounds the control internals keep their stock greys,
        producing the "fake dark" look.

        Strategy: style selectors override the exposed ThemeResource surfaces of each control
        using our palette. Keys are picked to work against Avalonia 12's Fluent theme.
    -->

    <!-- ===================================================================== -->
    <!-- Window / base                                                         -->
    <!-- ===================================================================== -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource BaseBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <!-- ===================================================================== -->
    <!-- ScrollBar — thin overlay rail                                         -->
    <!-- ===================================================================== -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ScrollBar /template/ Border#TrackBackground">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="8" />
    </Style>
    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="8" />
    </Style>
    <Style Selector="ScrollBar Thumb">
        <Setter Property="Background" Value="{DynamicResource Overlay0Brush}" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="ScrollBar Thumb:pointerover">
        <Setter Property="Background" Value="{DynamicResource Overlay1Brush}" />
    </Style>
    <Style Selector="ScrollBar Thumb:pressed">
        <Setter Property="Background" Value="{DynamicResource Overlay2Brush}" />
    </Style>
    <Style Selector="ScrollBar RepeatButton">
        <Setter Property="Opacity" Value="0" />
    </Style>

    <!-- ===================================================================== -->
    <!-- ToolTip                                                               -->
    <!-- ===================================================================== -->
    <Style Selector="ToolTip">
        <Setter Property="Background" Value="{DynamicResource CrustBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- ===================================================================== -->
    <!-- Menu / ContextMenu / MenuFlyoutPresenter                              -->
    <!-- ===================================================================== -->
    <Style Selector="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource MantleBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Background" Value="{DynamicResource MantleBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,6" />
    </Style>
    <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    </Style>
    <Style Selector="MenuItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    </Style>
    <Style Selector="Menu">
        <Setter Property="Background" Value="{DynamicResource MantleBrush}" />
    </Style>

    <!-- ===================================================================== -->
    <!-- ComboBox                                                              -->
    <!-- ===================================================================== -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    </Style>
    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource BlueBrush}" />
    </Style>
    <Style Selector="ComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,6" />
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="Foreground" Value="{DynamicResource BlueBrush}" />
    </Style>

    <!-- ===================================================================== -->
    <!-- TabControl / TabItem                                                  -->
    <!-- ===================================================================== -->
    <Style Selector="TabControl">
        <Setter Property="Background" Value="{DynamicResource BaseBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource Subtext0Brush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinHeight" Value="30" />
    </Style>
    <Style Selector="TabItem:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="TabItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource BlueBrush}" />
    </Style>

    <!-- ===================================================================== -->
    <!-- TreeView / TreeViewItem — kill white hover/selected                   -->
    <!-- ===================================================================== -->
    <Style Selector="TreeView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="TreeViewItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="TreeViewItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
    </Style>
    <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    </Style>
    <Style Selector="TreeViewItem:selected:focus /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    </Style>

    <!-- ===================================================================== -->
    <!-- ListBox / ListBoxItem                                                 -->
    <!-- ===================================================================== -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Margin" Value="2,1" />
        <Setter Property="Padding" Value="8,4" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    </Style>

    <!-- ===================================================================== -->
    <!-- Separator                                                             -->
    <!-- ===================================================================== -->
    <Style Selector="Separator">
        <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="0,6" />
    </Style>

    <!-- ===================================================================== -->
    <!-- Expander                                                              -->
    <!-- ===================================================================== -->
    <Style Selector="Expander">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
    </Style>

    <!-- ===================================================================== -->
    <!-- ScrollViewer                                                          -->
    <!-- ===================================================================== -->
    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="True" />
    </Style>

    <!-- ===================================================================== -->
    <!-- Dock.Avalonia ToolChromeControl chrome buttons (pin / maximize /      -->
    <!-- close). The Fluent preset's default PathIcon resources don't render  -->
    <!-- correctly here; we supply proper SVG content via a Template override. -->
    <!-- ===================================================================== -->
    <!-- PART_PinButton slot is repurposed as a "popout to floating window" button.
         MainWindow.axaml.cs intercepts the Click event and calls factory.FloatDockable()
         instead of the default PinDockable action (see OnChromeButtonClick). -->
    <Style Selector="ToolChromeControl /template/ Button#PART_PinButton">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ToolTip.Tip" Value="Pop out to new window" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}" CornerRadius="3">
                    <svg:Svg Path="{StaticResource PopoutIcon}" Width="13" Height="13"
                             Css="{DynamicResource SvgCssText}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsHitTestVisible="False" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="ToolChromeControl /template/ Button#PART_PinButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    </Style>

    <Style Selector="ToolChromeControl /template/ Button#PART_MaximizeRestoreButton">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}" CornerRadius="3">
                    <svg:Svg Path="{StaticResource MaximizeIcon}" Width="13" Height="13"
                             Css="{DynamicResource SvgCssText}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsHitTestVisible="False" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="ToolChromeControl /template/ Button#PART_MaximizeRestoreButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    </Style>

    <Style Selector="ToolChromeControl /template/ Button#PART_CloseButton">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}" CornerRadius="3">
                    <svg:Svg Path="{StaticResource CloseIcon}" Width="13" Height="13"
                             Css="{DynamicResource SvgCssText}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsHitTestVisible="False" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="ToolChromeControl /template/ Button#PART_CloseButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
    </Style>

    <!-- Menu (grip) button: no use case in current shell; hide for cleanliness. -->
    <Style Selector="ToolChromeControl /template/ Button#PART_MenuButton">
        <Setter Property="IsVisible" Value="False" />
    </Style>

    <!-- PART_Grip (dotted drag-handle strip) is bound to IToolDock.GripMode via
         a CompiledBinding, so an IsVisible Style setter is overridden. The grip
         is hidden at the data layer by setting GripMode=Hidden on each ToolDock
         in DockFactory.cs. -->
    <!-- Hide the tab-strip "create new document" (+) button (no action wired). -->
    <Style Selector="DocumentTabStrip /template/ Button">
        <Setter Property="IsVisible" Value="False" />
    </Style>
</Styles>

