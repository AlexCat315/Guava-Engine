<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Centralized icon path registry.
        SVG source files live in Assets/Icons/.
        Views reference these keys via {StaticResource XxxIcon}.
        To change an icon, update the path string here — all views update automatically.
    -->

    <!-- Transport -->
    <x:String x:Key="PlayIcon">/Assets/Icons/play.svg</x:String>
    <x:String x:Key="PauseIcon">/Assets/Icons/pause.svg</x:String>
    <x:String x:Key="StopIcon">/Assets/Icons/stop.svg</x:String>

    <!-- File actions -->
    <x:String x:Key="SaveIcon">/Assets/Icons/save.svg</x:String>
    <x:String x:Key="UndoIcon">/Assets/Icons/undo.svg</x:String>
    <x:String x:Key="RedoIcon">/Assets/Icons/redo.svg</x:String>

    <!-- Navigation -->
    <x:String x:Key="BackIcon">/Assets/Icons/arrow-left.svg</x:String>
    <x:String x:Key="ChevronRightIcon">/Assets/Icons/chevron-right.svg</x:String>

    <!-- Objects -->
    <x:String x:Key="CubeIcon">/Assets/Icons/cube.svg</x:String>
    <x:String x:Key="SphereIcon">/Assets/Icons/icon-filled-circle.svg</x:String>
    <x:String x:Key="GlobeIcon">/Assets/Icons/globe.svg</x:String>
    <x:String x:Key="CameraIcon">/Assets/Icons/camera.svg</x:String>
    <x:String x:Key="SunIcon">/Assets/Icons/light_sun.svg</x:String>
    <x:String x:Key="GroundIcon">/Assets/Icons/squares-2x2.svg</x:String>
    <x:String x:Key="CrosshairIcon">/Assets/Icons/crosshair.svg</x:String>

    <!-- Tools -->
    <x:String x:Key="MoveIcon">/Assets/Icons/arrows-pointing-out.svg</x:String>
    <x:String x:Key="SearchIcon">/Assets/Icons/magnifying-glass.svg</x:String>
    <x:String x:Key="DeleteIcon">/Assets/Icons/delete.svg</x:String>
    <x:String x:Key="PlusIcon">/Assets/Icons/plus.svg</x:String>
    <x:String x:Key="CogIcon">/Assets/Icons/cog-6-tooth.svg</x:String>
    <x:String x:Key="PaintBrushIcon">/Assets/Icons/paint-brush.svg</x:String>

    <!-- Content types -->
    <x:String x:Key="FolderIcon">/Assets/Icons/folder.svg</x:String>
    <x:String x:Key="PhotoIcon">/Assets/Icons/photo.svg</x:String>
    <x:String x:Key="CodeIcon">/Assets/Icons/code-bracket.svg</x:String>
    <x:String x:Key="DocumentIcon">/Assets/Icons/document-text.svg</x:String>

    <!-- Status -->
    <x:String x:Key="InfoIcon">/Assets/Icons/information-circle.svg</x:String>
    <x:String x:Key="WarningIcon">/Assets/Icons/exclamation-triangle.svg</x:String>
    <x:String x:Key="ErrorIcon">/Assets/Icons/x-circle.svg</x:String>

</ResourceDictionary>
