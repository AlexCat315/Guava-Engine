---
# Clangd configuration for Guava workspace.
# Use per-project compilation databases, no merged database.

# Engine sources: use Zig-generated database.
If:
  PathMatch: ^packages/engine/.*
CompileFlags:
  CompilationDatabase: packages/engine

---
# Qt6 editor sources: use CMake-generated database.
If:
  PathMatch: ^packages/editor_qt6/(src|qml|build)/.*
CompileFlags:
  CompilationDatabase: packages/editor_qt6/build

---
# Global diagnostics and editor assistance.
Diagnostics:
  ClangTidy:
    Add: [performance-*, modernize-*, bugprone-*, clang-analyzer-*]
    Remove: [readability-identifier-length]
  Suppress:
    - "readability-named-parameter"
    - "misc-non-private-member-variables-in-classes"

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true

Completion:
  AllScopes: true
